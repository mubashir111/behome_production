# Copy this file to .env.production (or set these as server env vars).
# ALL variables below are required in production — the build will fail without them.

# ── Backend (server-only) ─────────────────────────────────────────
# Internal or public URL of the Laravel API. Never use localhost here.
BACKEND_URL=https://api.behom.ae

# Hostname used by Next.js Image Optimization to allow backend images.
# Must match the hostname in BACKEND_URL (without protocol).
IMAGE_HOSTNAME=api.behom.ae

# API key injected by middleware into every /api/* proxy request.
# Must match the API_KEY in the Laravel .env (MIX_API_KEY / API_KEY).
API_KEY=your-api-key-here

# ── Public variables (bundled into client JS) ─────────────────────
NEXT_PUBLIC_SITE_URL=https://behom.ae

# ── Optional: Google OAuth ────────────────────────────────────────
# Only the Client ID goes here — the Client Secret stays in the Laravel .env.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
