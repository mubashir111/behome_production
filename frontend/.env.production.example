# NEXT_PUBLIC_API_URL should point to your backend API
# In production, this is usually the same domain as the site URL
NEXT_PUBLIC_API_URL=https://yourdomain.com/api

# MIX_API_KEY should match the MIX_API_KEY in the root .env
NEXT_PUBLIC_API_KEY=

# NEXT_PUBLIC_SITE_URL should be your live site URL
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
