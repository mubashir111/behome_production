{
    "private": true,
    "scripts": {
        "dev": "npm run development",
        "development": "mix",
        "watch": "mix watch",
        "watch-poll": "mix watch -- --watch-options-poll=1000",
        "hot": "mix watch --hot",
        "prod": "npm run production",
        "production": "mix --production",
        "frontend-dev": "cd frontend && npm run dev",
        "backend-dev": "php artisan serve",
        "dev-all": "npm run backend-dev & npm run frontend-dev",
        "build:css": "cd frontend && npm run build:css"
    },
    "devDependencies": {
        "@popperjs/core": "^2.10.2",
        "autoprefixer": "^10.4.14",
        "axios": "^1.1.2",
        "bootstrap": "^5.2.1",
        "laravel-mix": "^6.0.15",
        "lodash": "^4.17.19",
        "postcss": "^8.4.25",
        "sass": "^1.32.11",
        "tailwindcss": "^3.3.2",
        "vite": "^3.0.0"
    },
    "dependencies": {
        "babel-loader": "^9.1.0",
        "city-state-country": "^2.1.0",
        "firebase": "^10.5.0",
        "swiper": "^10.2.0"
    }
}

